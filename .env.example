# Порт HTTP-сервера
PORT=3000

# Секрет для подписи JWT. Обязательно замените перед запуском в бою.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Файл базы данных SQLite
DB_FILE=./data/app.db

# Провайдер SMS: console (коды в лог, для разработки) или ваш провайдер
SMS_PROVIDER=console
SMS_CODE_TTL_MINUTES=10

# За сколько часов до начала волонтер может отменить запись
CANCEL_DEADLINE_HOURS=24
